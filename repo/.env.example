COMPOSE_PROJECT_NAME=vetops

# If Docker Hub (auth.docker.io) times out or DNS fails, use a mirror prefix for *builds* (must end with /).
# Example (DaoCloud public mirror): DOCKER_IMAGE_REGISTRY_PREFIX=docker.m.daocloud.io/library/
# DOCKER_IMAGE_REGISTRY_PREFIX=

# Optional: same mirror for mysql image pulls (no trailing path — full image ref).
# Example: MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4

# Global runtime
TZ=UTC
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=
LOG_CHANNEL=stack
LOG_LEVEL=info

# MySQL
MYSQL_DATABASE=vetops
MYSQL_USER=vetops
MYSQL_PASSWORD=change_me_for_lan
MYSQL_ROOT_PASSWORD=change_me_for_lan_root

# Frontend ports
FRONTEND_PORT=8080
FRONTEND_DEV_PORT=5173

# Frontend build/runtime API settings
VITE_API_BASE_PATH=/api/v1
VITE_BACKEND_ORIGIN=http://backend:8000

# Backend startup controls
RUN_MIGRATIONS=true
RUN_SEEDERS=false
WARMUP_CACHE=true
WAIT_FOR_DB=true
DB_WAIT_MAX_ATTEMPTS=60

# CORS
FRONTEND_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

VETOPS_AUTH_CAPTCHA_BYPASS_TOKEN=change_me_to_a_random_secret
VETOPS_AUDIT_RETENTION_YEARS=7
VITE_WORKSTATION_ID=ws-terminal-01
